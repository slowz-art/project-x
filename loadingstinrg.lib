--[[
    GameSelector.lua
    EXACT layout match from your screenshot
    "DETECTED GAMETHA BRONX3" on ONE line
    "GAMESELECTOR" centered
    "choose your experience" lowercase
    Three game buttons
    Three action buttons at bottom
--]]

local GameSelector = {}
GameSelector.__index = GameSelector

-- ─── SERVICES ───
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local MarketplaceService = game:GetService("MarketplaceService")

-- ─── YOUR CONFIG ───
local ACCENT = Color3.fromRGB(255, 60, 80)

local GAME_PLACE_IDS = {
    ThaBronx3 = 16472538603,
    PhillyStreetz2 = 130700367963690,
    CentralStreets = 121567535120062,
}

local GAME_NAMES = {
    ThaBronx3 = "THA BRONX 3",
    PhillyStreetz2 = "PHILLY STREETZ 2",
    CentralStreets = "CENTRAL STREETS",
}

local GAME_SCRIPTS = {
    ThaBronx3 = function()
        print("Loading ThaBronx3 script...")
        task.wait(2)
        print("ThaBronx3 script loaded!")
    end,
    PhillyStreetz2 = function()
        print("Loading PhillyStreetz2 script...")
        task.wait(2)
        print("PhillyStreetz2 script loaded!")
    end,
    CentralStreets = function()
        print("Loading CentralStreets script...")
        task.wait(2)
        print("CentralStreets script loaded!")
    end,
}

local GAMES = {
    ThaBronx3 = {
        Key = "ThaBronx3",
        Name = "THABRONX3",
        DisplayName = "THA BRONX 3",
        PlaceId = 16472538603,
        Color = Color3.fromRGB(200, 50, 50),
        Script = GAME_SCRIPTS.ThaBronx3,
    },
    PhillyStreetz2 = {
        Key = "PhillyStreetz2",
        Name = "PHILLYSTREETZ2",
        DisplayName = "PHILLY STREETZ 2",
        PlaceId = 130700367963690,
        Color = Color3.fromRGB(50, 150, 200),
        Script = GAME_SCRIPTS.PhillyStreetz2,
    },
    CentralStreets = {
        Key = "CentralStreets",
        Name = "CENTRALSTREETS",
        DisplayName = "CENTRAL STREETS",
        PlaceId = 121567535120062,
        Color = Color3.fromRGB(50, 200, 100),
        Script = GAME_SCRIPTS.CentralStreets,
    },
}

-- ─── HELPERS ───
local function createRoundedFrame(parent, size, position, color, transparency, cornerRadius)
    local frame = Instance.new("Frame")
    frame.Size = size
    frame.Position = position
    frame.BackgroundColor3 = color or Color3.fromRGB(255, 255, 255)
    frame.BackgroundTransparency = transparency or 0
    frame.BorderSizePixel = 0
    frame.Parent = parent
    
    if cornerRadius and cornerRadius > 0 then
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, cornerRadius)
        corner.Parent = frame
    end
    
    return frame
end

local function createTextLabel(parent, size, position, text, color, sizePx, font, alignX, alignY, transparency)
    local label = Instance.new("TextLabel")
    label.Size = size
    label.Position = position
    label.BackgroundTransparency = transparency or 1
    label.Text = text or ""
    label.TextColor3 = color or Color3.fromRGB(255, 255, 255)
    label.TextSize = sizePx or 14
    label.Font = font or Enum.Font.SourceSansBold
    label.TextXAlignment = alignX or Enum.TextXAlignment.Center
    label.TextYAlignment = alignY or Enum.TextYAlignment.Center
    label.Parent = parent
    return label
end

local function createImageLabel(parent, size, position, imageId, transparency)
    local image = Instance.new("ImageLabel")
    image.Size = size
    image.Position = position
    image.BackgroundTransparency = 1
    image.Image = imageId or ""
    image.ImageTransparency = transparency or 0
    image.ScaleType = Enum.ScaleType.Fit
    image.Parent = parent
    return image
end

local function createButton(parent, size, position, text, color, textColor, cornerRadius, textSize)
    local btn = Instance.new("TextButton")
    btn.Size = size
    btn.Position = position
    btn.BackgroundColor3 = color or Color3.fromRGB(40, 40, 40)
    btn.Text = text or ""
    btn.TextColor3 = textColor or Color3.fromRGB(255, 255, 255)
    btn.TextSize = textSize or 14
    btn.Font = Enum.Font.SourceSansBold
    btn.BorderSizePixel = 0
    btn.Parent = parent
    btn.AutoButtonColor = false
    
    if cornerRadius and cornerRadius > 0 then
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, cornerRadius)
        corner.Parent = btn
    end
    
    return btn
end

-- ─── MAIN CLASS ───
function GameSelector.new(config)
    config = config or {}
    
    local self = setmetatable({}, GameSelector)
    
    -- ─── CONFIG ───
    self.Parent = config.Parent or Players.LocalPlayer.PlayerGui
    self.Position = config.Position or UDim2.new(0.5, -250, 0.5, -210)
    self.Size = config.Size or UDim2.new(0, 500, 0, 420)
    self.LogoId = config.LogoId or "rbxassetid://93352692321785"
    self.AccentColor = config.AccentColor or ACCENT
    self.OnGameSelected = config.OnGameSelected or function(gameKey) end
    self.OnLoadScript = config.OnLoadScript or function(gameKey) end
    self.OnJoin = config.OnJoin or function(gameKey) end
    
    -- ─── STATE ───
    self.SelectedGame = nil
    self.CurrentGame = nil
    self.IsLoading = false
    
    -- ─── DETECT CURRENT GAME ───
    self:_detectCurrentGame()
    
    -- ─── BUILD UI ───
    self:_buildUI()
    
    -- ─── UPDATE UI ───
    self:_updateUI()
    
    return self
end

-- ─── DETECT CURRENT GAME ───
function GameSelector:_detectCurrentGame()
    local placeId = game.PlaceId
    
    for key, id in pairs(GAME_PLACE_IDS) do
        if id == placeId then
            self.CurrentGame = key
            return
        end
    end
    
    local gameName = MarketplaceService:GetProductInfo(placeId).Name or ""
    for key, name in pairs(GAME_NAMES) do
        if string.find(string.upper(gameName), string.upper(name)) or string.find(string.upper(gameName), string.upper(key)) then
            self.CurrentGame = key
            return
        end
    end
    
    self.CurrentGame = "ThaBronx3"
end

-- ─── UPDATE UI ───
function GameSelector:_updateUI()
    if not self.CurrentGame then return end
    
    local gameData = GAMES[self.CurrentGame]
    if not gameData then return end
    
    -- "DETECTED GAMETHA BRONX3" on ONE line
    if self.DetectedLabel then
        self.DetectedLabel.Text = "DETECTED " .. gameData.Name
        self.DetectedLabel.TextColor3 = self.AccentColor
    end
    
    -- Auto-select current game
    for i, btn in ipairs(self.GameButtons or {}) do
        if btn._GameKey == self.CurrentGame then
            self:SelectGame(i)
            break
        end
    end
end

-- ─── BUILD UI ───
function GameSelector:_buildUI()
    -- ─── MAIN CONTAINER ───
    local main = createRoundedFrame(
        self.Parent,
        self.Size,
        self.Position,
        Color3.fromRGB(18, 16, 20),
        0,
        12
    )
    main.BorderSizePixel = 2
    main.BorderColor3 = Color3.fromRGB(60, 55, 65)
    self.Main = main
    
    -- ─── LOGO (top center) ───
    local logo = createImageLabel(
        main,
        UDim2.new(0, 60, 0, 60),
        UDim2.new(0.5, -30, 0, 8),
        self.LogoId,
        0
    )
    self.Logo = logo
    
    -- ─── "DETECTED GAMETHA BRONX3" (ONE LINE) ───
    local currentData = GAMES[self.CurrentGame] or GAMES["ThaBronx3"]
    local detectedLabel = createTextLabel(
        main,
        UDim2.new(1, 0, 0, 30),
        UDim2.new(0, 0, 0, 75),
        "DETECTED " .. currentData.Name,
        self.AccentColor,
        14,
        Enum.Font.SourceSansBold
    )
    self.DetectedLabel = detectedLabel
    
    -- ─── "GAMESELECTOR" ───
    local selectorLabel = createTextLabel(
        main,
        UDim2.new(1, 0, 0, 28),
        UDim2.new(0, 0, 0, 108),
        "GAMESELECTOR",
        Color3.fromRGB(140, 140, 160),
        11,
        Enum.Font.SourceSans,
        Enum.TextXAlignment.Center,
        Enum.TextYAlignment.Center,
        0.6
    )
    self.SelectorLabel = selectorLabel
    
    -- ─── "choose your experience" (lowercase) ───
    local subtitleLabel = createTextLabel(
        main,
        UDim2.new(1, 0, 0, 22),
        UDim2.new(0, 0, 0, 136),
        "choose your experience",
        Color3.fromRGB(160, 160, 180),
        10,
        Enum.Font.SourceSans,
        Enum.TextXAlignment.Center,
        Enum.TextYAlignment.Center,
        0.5
    )
    self.SubtitleLabel = subtitleLabel
    
    -- ─── DIVIDER LINE ───
    local divider = Instance.new("Frame")
    divider.Size = UDim2.new(0.7, 0, 0, 1)
    divider.Position = UDim2.new(0.15, 0, 0, 162)
    divider.BackgroundColor3 = Color3.fromRGB(50, 45, 55)
    divider.Parent = main
    self.Divider = divider
    
    -- ─── GAME BUTTONS ───
    local gameButtons = {}
    local buttonHeight = 34
    local buttonSpacing = 6
    local startY = 178
    
    local gameOrder = {"ThaBronx3", "PhillyStreetz2", "CentralStreets"}
    
    for i, key in ipairs(gameOrder) do
        local gameData = GAMES[key]
        if gameData then
            local yPos = startY + (i - 1) * (buttonHeight + buttonSpacing)
            local isCurrent = (key == self.CurrentGame)
            
            local btn = createButton(
                main,
                UDim2.new(0.7, 0, 0, buttonHeight),
                UDim2.new(0.15, 0, 0, yPos),
                gameData.Name,
                isCurrent and gameData.Color or Color3.fromRGB(35, 33, 38),
                isCurrent and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 220),
                6,
                13
            )
            btn.BorderSizePixel = 1
            btn.BorderColor3 = isCurrent and gameData.Color or Color3.fromRGB(50, 45, 55)
            btn._GameKey = key
            btn._GameData = gameData
            
            if isCurrent then
                btn.BackgroundColor3 = gameData.Color
                btn.BackgroundTransparency = 0.25
            end
            
            btn.MouseEnter:Connect(function()
                if not isCurrent and not self.IsLoading then
                    TweenService:Create(btn, TweenInfo.new(0.12), {
                        BackgroundColor3 = Color3.fromRGB(50, 45, 55)
                    }):Play()
                end
            end)
            
            btn.MouseLeave:Connect(function()
                if not isCurrent and not self.IsLoading then
                    TweenService:Create(btn, TweenInfo.new(0.12), {
                        BackgroundColor3 = Color3.fromRGB(35, 33, 38)
                    }):Play()
                end
            end)
            
            btn.MouseButton1Click:Connect(function()
                if not self.IsLoading then
                    self:SelectGame(i)
                end
            end)
            
            table.insert(gameButtons, btn)
        end
    end
    self.GameButtons = gameButtons
    
    -- ─── ACTION BUTTONS ───
    local actionY = startY + #gameOrder * (buttonHeight + buttonSpacing) + 12
    local btnWidth = 0.3
    local btnSpacing = 0.025
    
    -- "CLICK TO LOAD SCRIPT" (left)
    local loadBtn = createButton(
        main,
        UDim2.new(btnWidth, 0, 0, 30),
        UDim2.new(0.05, 0, 0, actionY),
        "CLICK TO LOAD SCRIPT",
        Color3.fromRGB(55, 50, 65),
        Color3.fromRGB(190, 190, 210),
        6,
        9
    )
    loadBtn.BorderSizePixel = 1
    loadBtn.BorderColor3 = Color3.fromRGB(75, 70, 85)
    loadBtn._Action = "load"
    
    loadBtn.MouseEnter:Connect(function()
        if not self.IsLoading then
            TweenService:Create(loadBtn, TweenInfo.new(0.12), {
                BackgroundColor3 = Color3.fromRGB(75, 70, 85)
            }):Play()
        end
    end)
    
    loadBtn.MouseLeave:Connect(function()
        if not self.IsLoading then
            TweenService:Create(loadBtn, TweenInfo.new(0.12), {
                BackgroundColor3 = Color3.fromRGB(55, 50, 65)
            }):Play()
        end
    end)
    
    loadBtn.MouseButton1Click:Connect(function()
        self:_handleLoadScript()
    end)
    self.LoadButton = loadBtn
    
    -- "CLICK TO JOIN & LOAD" (center)
    local joinBtn = createButton(
        main,
        UDim2.new(btnWidth, 0, 0, 30),
        UDim2.new(0.05 + btnWidth + btnSpacing, 0, 0, actionY),
        "CLICK TO JOIN & LOAD",
        Color3.fromRGB(40, 65, 95),
        Color3.fromRGB(210, 225, 255),
        6,
        9
    )
    joinBtn.BorderSizePixel = 1
    joinBtn.BorderColor3 = Color3.fromRGB(60, 95, 135)
    joinBtn._Action = "join"
    
    joinBtn.MouseEnter:Connect(function()
        if not self.IsLoading then
            TweenService:Create(joinBtn, TweenInfo.new(0.12), {
                BackgroundColor3 = Color3.fromRGB(50, 85, 125)
            }):Play()
        end
    end)
    
    joinBtn.MouseLeave:Connect(function()
        if not self.IsLoading then
            TweenService:Create(joinBtn, TweenInfo.new(0.12), {
                BackgroundColor3 = Color3.fromRGB(40, 65, 95)
            }):Play()
        end
    end)
    
    joinBtn.MouseButton1Click:Connect(function()
        self:_handleJoin()
    end)
    self.JoinButton = joinBtn
    
    -- "CLICK TO JOIN & LOAD" (right)
    local joinBtn2 = createButton(
        main,
        UDim2.new(btnWidth, 0, 0, 30),
        UDim2.new(0.05 + (btnWidth + btnSpacing) * 2, 0, 0, actionY),
        "CLICK TO JOIN & LOAD",
        Color3.fromRGB(40, 65, 95),
        Color3.fromRGB(210, 225, 255),
        6,
        9
    )
    joinBtn2.BorderSizePixel = 1
    joinBtn2.BorderColor3 = Color3.fromRGB(60, 95, 135)
    joinBtn2._Action = "join"
    
    joinBtn2.MouseEnter:Connect(function()
        if not self.IsLoading then
            TweenService:Create(joinBtn2, TweenInfo.new(0.12), {
                BackgroundColor3 = Color3.fromRGB(50, 85, 125)
            }):Play()
        end
    end)
    
    joinBtn2.MouseLeave:Connect(function()
        if not self.IsLoading then
            TweenService:Create(joinBtn2, TweenInfo.new(0.12), {
                BackgroundColor3 = Color3.fromRGB(40, 65, 95)
            }):Play()
        end
    end)
    
    joinBtn2.MouseButton1Click:Connect(function()
        self:_handleJoin()
    end)
    self.JoinButton2 = joinBtn2
end

-- ─── HANDLE LOAD SCRIPT ───
function GameSelector:_handleLoadScript()
    if self.IsLoading then return end
    
    local gameKey = self.SelectedGame or self.CurrentGame
    if not gameKey then
        self:_showStatus("No game selected!", Color3.fromRGB(255, 70, 70))
        return
    end
    
    local gameData = GAMES[gameKey]
    if not gameData then return end
    
    self.IsLoading = true
    self:_showStatus("Loading " .. gameData.DisplayName .. "...", gameData.Color)
    self:_setButtonsEnabled(false)
    
    self.OnLoadScript(gameKey)
    
    if gameData.Script then
        task.spawn(function()
            gameData.Script()
            self:_showStatus("✓ " .. gameData.DisplayName .. " loaded!", Color3.fromRGB(50, 200, 100))
            self.IsLoading = false
            self:_setButtonsEnabled(true)
        end)
    else
        task.wait(1)
        self:_showStatus("✓ Script loaded!", Color3.fromRGB(50, 200, 100))
        self.IsLoading = false
        self:_setButtonsEnabled(true)
    end
end

-- ─── HANDLE JOIN ───
function GameSelector:_handleJoin()
    if self.IsLoading then return end
    
    local gameKey = self.SelectedGame or self.CurrentGame
    if not gameKey then
        self:_showStatus("No game selected!", Color3.fromRGB(255, 70, 70))
        return
    end
    
    local gameData = GAMES[gameKey]
    if not gameData then return end
    
    if gameKey == self.CurrentGame then
        self:_showStatus("Already in " .. gameData.DisplayName .. "!", Color3.fromRGB(255, 200, 50))
        return
    end
    
    self.IsLoading = true
    self:_showStatus("Joining " .. gameData.DisplayName .. "...", gameData.Color)
    self:_setButtonsEnabled(false)
    
    self.OnJoin(gameKey)
    
    local success, err = pcall(function()
        TeleportService:Teleport(gameData.PlaceId, Players.LocalPlayer)
    end)
    
    if not success then
        self:_showStatus("Failed to teleport!", Color3.fromRGB(255, 70, 70))
        self.IsLoading = false
        self:_setButtonsEnabled(true)
    end
end

-- ─── SHOW STATUS ───
function GameSelector:_showStatus(message, color)
    if self.StatusLabel then
        self.StatusLabel.Text = message
        self.StatusLabel.TextColor3 = color or Color3.fromRGB(200, 200, 200)
    end
end

-- ─── SET BUTTONS ENABLED ───
function GameSelector:_setButtonsEnabled(enabled)
    local transparency = enabled and 0 or 0.5
    
    for _, btn in ipairs(self.GameButtons or {}) do
        btn.TextTransparency = transparency
        btn.BackgroundTransparency = enabled and (btn._GameKey == self.CurrentGame and 0.25 or 0) or 0.5
    end
    
    if self.LoadButton then
        self.LoadButton.TextTransparency = transparency
        self.LoadButton.BackgroundTransparency = enabled and 0 or 0.5
    end
    if self.JoinButton then
        self.JoinButton.TextTransparency = transparency
        self.JoinButton.BackgroundTransparency = enabled and 0 or 0.5
    end
    if self.JoinButton2 then
        self.JoinButton2.TextTransparency = transparency
        self.JoinButton2.BackgroundTransparency = enabled and 0 or 0.5
    end
end

-- ─── SELECT GAME ───
function GameSelector:SelectGame(index)
    if self.IsLoading then return end
    
    local btn = self.GameButtons and self.GameButtons[index]
    if not btn then return end
    
    local gameKey = btn._GameKey
    local gameData = GAMES[gameKey]
    if not gameData then return end
    
    self.SelectedGame = gameKey
    
    for i, b in ipairs(self.GameButtons) do
        if b._GameKey == gameKey then
            b.BackgroundColor3 = gameData.Color
            b.BackgroundTransparency = 0.25
            b.BorderColor3 = gameData.Color
            b.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            b.BackgroundColor3 = Color3.fromRGB(35, 33, 38)
            b.BackgroundTransparency = 0
            b.BorderColor3 = Color3.fromRGB(50, 45, 55)
            b.TextColor3 = Color3.fromRGB(200, 200, 220)
        end
    end
    
    -- Update detected label to show selection
    if self.DetectedLabel then
        self.DetectedLabel.Text = "SELECTED " .. gameData.Name
        self.DetectedLabel.TextColor3 = gameData.Color
    end
    
    self:_showStatus("Selected: " .. gameData.DisplayName, gameData.Color)
    self.OnGameSelected(gameKey)
end

-- ─── PUBLIC METHODS ───
function GameSelector:GetCurrentGame()
    return self.CurrentGame, GAMES[self.CurrentGame]
end

function GameSelector:GetSelectedGame()
    return self.SelectedGame, GAMES[self.SelectedGame]
end

function GameSelector:SetStatus(message, color)
    self:_showStatus(message, color)
end

function GameSelector:Destroy()
    if self.Main then
        self.Main:Destroy()
    end
end

return GameSelector
